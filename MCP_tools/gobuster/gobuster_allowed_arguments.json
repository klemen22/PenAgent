{
  "commands": {
    "web_enumeration": {
      "safe": [
        {
          "name": "dir",
          "description": "Directory and file enumeration mode"
        },
        {
          "name": "vhost",
          "description": "Virtual host enumeration mode. Used when multiple domains share the same server"
        }
      ]
    },

    "infrastructure_enumeration": {
      "safe": [
        {
          "name": "dns",
          "description": "DNS subdomain enumeration mode"
        },
        {
          "name": "tftp",
          "description": "TFTP enumeration mode"
        },
        {
          "name": "s3",
          "description": "AWS S3 bucket enumeration mode"
        },
        {
          "name": "gcs",
          "description": "Google Cloud Storage bucket enumeration mode"
        }
      ]
    },

    "utility": {
      "info": [
        {
          "name": "help",
          "aliases": ["h"],
          "description": "Shows a list of commands or help for one command"
        }
      ]
    }
  },

  "dir_options": {
    "safe": [
      {
        "name": "-x",
        "type": "string",
        "description": "File extensions to search (e.g., -x php,txt,html)"
      },
      { "name": "-k", "description": "Skip SSL certificate verification" },
      {
        "name": "-a",
        "type": "string",
        "description": "Set User-Agent string"
      },
      {
        "name": "--random-agent",
        "description": "Use a random User-Agent string"
      }
    ],
    "aggressive": [
      {
        "name": "-c",
        "type": "string",
        "description": "Cookies to use (e.g., -c 'session=1234')"
      },
      {
        "name": "-b",
        "type": "string",
        "description": "Status codes to ignore (e.g., -b 403,404)"
      }
    ]
  },

  "global_options": {
    "information": [
      {
        "name": "--help",
        "alias": "-h",
        "description": "Show help menu"
      },
      {
        "name": "--version",
        "alias": "-v",
        "description": "Print Gobuster version"
      }
    ]
  },

  "agent_constraints": {
    "recommended_default_command": "dir",
    "notes": [
      "Use 'dir' for HTTP directory and file enumeration",
      "Do not switch enumeration mode unless explicitly required",
      "Most web enumeration tasks should use 'dir'"
    ]
  }
}
